# Discord Bot Token (get from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Channel ID where the bot converts music links to song.link (right-click channel > Copy ID)
CHANNEL_ID=your_channel_id_here

# Channel ID where the bot downloads and re-uploads social media videos
# Supports: Instagram Reels, TikTok, Twitter/X, YouTube Shorts, Reddit, Twitch clips, Streamable, and more
# Can be the same as CHANNEL_ID if desired
SOCIAL_CHANNEL_ID=your_social_channel_id_here

# (Optional) Cobalt API instance URL for social media downloads
# Defaults to https://cobalt-backend.canine.tools — override to use your own self-hosted instance
# COBALT_API_URL=https://cobalt-backend.canine.tools
